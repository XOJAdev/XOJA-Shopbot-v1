<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('web_admin_portal') %> - Top-Up Bot</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #04AA6D;
            --primary-hover: #038d5a;
            --bg: #f8fafc;
            --text-main: #1e293b;
            --border: #e2e8f0;
        }

        body { 
            font-family: 'Inter', sans-serif; 
            background-color: var(--bg); 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            height: 100vh; 
            margin: 0; 
            color: var(--text-main);
        }

        .login-container { 
            background: white; 
            padding: 40px; 
            border-radius: 16px; 
            box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1), 0 8px 10px -6px rgba(0,0,0,0.1); 
            width: 100%; 
            max-width: 400px; 
            box-sizing: border-box;
        }

        h2 { 
            text-align: center; 
            margin-top: 0;
            margin-bottom: 32px;
            font-size: 24px;
            font-weight: 700;
        }

        .form-group { margin-bottom: 20px; }

        label { 
            display: block; 
            margin-bottom: 8px; 
            font-weight: 500;
            font-size: 14px;
            color: #64748b;
        }

        input { 
            width: 100%; 
            padding: 12px 16px; 
            border: 1px solid var(--border); 
            border-radius: 8px; 
            box-sizing: border-box; 
            font-family: inherit;
            font-size: 15px;
            transition: all 0.2s;
        }

        input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(4, 170, 109, 0.1);
        }

        button { 
            width: 100%; 
            padding: 12px; 
            background-color: var(--primary); 
            color: white; 
            border: none; 
            border-radius: 8px; 
            cursor: pointer; 
            font-size: 16px; 
            font-weight: 600;
            transition: background 0.2s;
            margin-top: 10px;
        }

        button:hover { 
            background-color: var(--primary-hover); 
        }

        .error { 
            background-color: #fee2e2; 
            color: #991b1b; 
            padding: 12px;
            border-radius: 8px;
            text-align: center; 
            margin-bottom: 24px; 
            font-size: 14px;
            font-weight: 500;
        }

        @media (max-width: 480px) {
            .login-container {
                padding: 30px 20px;
                border-radius: 0;
                height: 100vh;
                display: flex;
                flex-direction: column;
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <div class="login-container">
        <h2><%= t('web_admin_portal') %></h2>
        <% if (error) { %>
            <div class="error"><%= error %></div>
        <% } %>
        <form action="/login" method="POST">
            <div class="form-group">
                <label for="username"><%= t('web_username') %></label>
                <input type="text" id="username" name="username" required autocomplete="username">
            </div>
            <div class="form-group">
                <label for="password"><%= t('web_password') %></label>
                <input type="password" id="password" name="password" required autocomplete="current-password">
            </div>
            <button type="submit"><%= t('web_login_btn') %></button>
        </form>
    </div>
</body>
</html>
